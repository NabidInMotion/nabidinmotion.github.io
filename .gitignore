.cache/
.puppeteer_cache/
.npm/

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- OS / editor ---
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
*.swp
*~

